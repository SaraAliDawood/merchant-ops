# Copy to .env before running.
# SQLite by default so the app runs with zero external services.
# For Postgres, swap the datasource provider in prisma/schema.prisma to "postgresql"
# and set DATABASE_URL to your connection string.
DATABASE_URL="file:./dev.db"

# Secret used to sign JWT session tokens. Use a long random string in production.
AUTH_SECRET="dev-only-change-me-to-a-long-random-string"
